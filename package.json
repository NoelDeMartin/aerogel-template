{
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vp build",
        "dev": "vp dev",
        "dev:serve-pod": "community-solid-server -c @css:config/file.json -f ./solid",
        "deploy": "noeldemartin-deploy-app",
        "e2e:dev": "concurrently --kill-others \"pnpm e2e:serve-app\" \"pnpm e2e:serve-pod\" \"pnpm e2e:open\"",
        "e2e:open": "UI=true playwright test --ui",
        "e2e:run": "playwright test",
        "e2e:serve-app": "vp dev --port 5001 --mode testing",
        "e2e:serve-pod": "community-solid-server -l warn",
        "e2e:test:chromium": "start-server-and-test e2e:serve-app http-get://localhost:5001 e2e:serve-pod http-get://localhost:3000 'pnpm run e2e:run --project=chromium'",
        "e2e:test:firefox": "start-server-and-test e2e:serve-app http-get://localhost:5001 e2e:serve-pod http-get://localhost:3000 'pnpm run e2e:run --project=firefox'",
        "e2e:test:webkit": "start-server-and-test e2e:serve-app http-get://localhost:5001 e2e:serve-pod http-get://localhost:3000 'pnpm run e2e:run --project=webkit'",
        "type-check": "vue-tsc --noEmit"
    },
    "dependencies": {
        "@aerogel/core": "next",
        "@aerogel/plugin-i18n": "next",
        "@aerogel/plugin-local-first": "next",
        "@aerogel/plugin-routing": "next",
        "@aerogel/plugin-solid": "next",
        "@noeldemartin/solid-utils": "catalog:",
        "@noeldemartin/utils": "catalog:",
        "@tailwindcss/forms": "^0.5.10",
        "@tailwindcss/typography": "^0.5.16",
        "soukai-bis": "catalog:",
        "tailwindcss": "^4.1.1",
        "vue": "^3.5.13",
        "vue-i18n": "^11.1.2",
        "vue-router": "^4.5.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@aerogel/cli": "next",
        "@aerogel/playwright": "next",
        "@aerogel/vite": "next",
        "@iconify/json": "2.2.341",
        "@intlify/unplugin-vue-i18n": "^6.0.5",
        "@noeldemartin/scripts": "next",
        "@playwright/test": "^1.60.0",
        "@solid/community-server": "7.1.6",
        "@total-typescript/ts-reset": "^0.4.2",
        "@tsconfig/node24": "^24.0.3",
        "@types/node": "^24.10.4",
        "@vue/tsconfig": "^0.9.1",
        "concurrently": "^10.0.3",
        "start-server-and-test": "^3.0.8",
        "typescript": "~6.0.2",
        "unplugin-icons": "^22.1.0",
        "unplugin-vue-components": "^28.4.1",
        "vite": "catalog:",
        "vite-plus": "catalog:",
        "vitest": "^3.0.9",
        "vue-tsc": "^3.2.7"
    },
    "packageManager": "pnpm@11.5.2"
}
